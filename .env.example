# OpenRouter — https://openrouter.ai/keys
# Option A: single key
OPENROUTER_API_KEY=sk-or-v1-...

# Option B: multiple keys (comma/newline separated)
# OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3

# Gemini direct API key(s)
# GEMINI_API_KEY=AIza...
# GEMINI_API_KEYS=AIzaKey1,AizaKey2

# Optional: coordinator model (default: first model in backend/models.py DEFAULT_MODELS)
# COORDINATOR_MODEL=openrouter/qwen/qwen3.6-plus-preview:free

# MetaCTF (ctf-metactf) — cookie from browser devtools; MCS_OPTIONS= is stripped automatically
# METACTF_COOKIE=METACTF_COMPETE=...
